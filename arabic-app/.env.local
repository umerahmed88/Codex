# ============================================================================
# .env.local — LOCAL RUNTIME CONFIG
# ============================================================================
# ⚠️  ONLY put EXPO_PUBLIC_* values here. These are baked into the app bundle
#     and are PUBLIC by design (visible to anyone who downloads the app), so
#     committing them leaks nothing.
#
# 🚫  NEVER put a real secret here — not the Supabase `service_role` key, the
#     Anthropic API key, or any webhook secret. Those go into Supabase's secret
#     store (`supabase secrets set ...`) or EAS secrets, NEVER this file.
#
# Restart `npx expo start` after editing — env is read at start time.
# ============================================================================

# --- Supabase (REQUIRED to boot the app) ------------------------------------
# From Supabase → Settings → API. Paste your two values between the = and EOL.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- Sentry (optional — crash reporting) ------------------------------------
EXPO_PUBLIC_SENTRY_DSN=

# --- RevenueCat PUBLIC SDK keys (optional — needed for the paywall) ---------
# These are PUBLISHABLE keys (safe to ship); the RevenueCat *secret* API key
# and webhook secret do NOT go here.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# --- Growth (optional; each feature stays off until its var is set) ----------
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
