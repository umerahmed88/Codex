# Copy to .env.local and fill in your values
# Never commit actual secrets — use EAS secrets for production

EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# RevenueCat PUBLIC SDK keys (safe to ship in the app — they only allow what
# your store products permit). One per platform.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# Phase 15 — Growth (all optional; each feature stays off until its var is set)
# PostHog product analytics (see docs/phase-15-growth.md)
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# Google sign-in: the OAuth *Web* client id (Supabase verifies against it)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
