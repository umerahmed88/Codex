# ===========================================================================
# Staging environment (Phase 16). Copy to .env.staging and point it at a
# SEPARATE Supabase project from production so test data never touches real
# users. Loaded for the EAS `preview` build profile (APP_ENV=preview).
# See docs/staging-environment.md.
# ===========================================================================

# A second, free Supabase project used only for staging/QA.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Separate Sentry environment tag is set automatically from APP_ENV; the DSN
# can be the same project (events are tagged by environment) or a staging one.
EXPO_PUBLIC_SENTRY_DSN=

# RevenueCat: use sandbox / a separate staging app so test purchases don't hit
# production entitlements.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# Growth (optional): use a separate PostHog project for staging so QA events
# don't pollute production funnels.
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
